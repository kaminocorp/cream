# Base URL of the Cream API server (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Operator API key — shared secret that authenticates the dashboard as the
# operator principal. Must match `OPERATOR_API_KEY` on the backend. Minimum
# 32 characters; generate with `openssl rand -hex 32`.
#
# Phase 15.1 interim model: a single shared key for all dashboard users.
# Phase 16-A replaces this with real per-user authentication (Clerk / Auth.js
# / Supabase Auth) backed by an `operators` table.
#
# Stored server-side only — never expose via NEXT_PUBLIC_* variables. The
# `CreamApiClient` in `lib/api.ts` reads this and injects it into the
# `Authorization: Bearer` header for every API call.
CREAM_API_KEY=your-operator-key-here

# Cream — Local Development Environment
# Copy to .env and adjust as needed.

# PostgreSQL
DATABASE_URL=postgres://cream:cream_dev@localhost:5432/cream

# Redis
REDIS_URL=redis://localhost:6379

# API server
API_HOST=0.0.0.0
API_PORT=8080

# Logging (see https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html)
RUST_LOG=cream_api=debug,cream_models=debug,cream_policy=debug,cream_providers=debug,cream_router=debug,cream_audit=debug,info

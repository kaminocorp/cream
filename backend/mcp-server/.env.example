# Cream MCP Server — local development environment.
# Copy to .env and adjust as needed.

# Base URL of the Cream Rust API server.
CREAM_API_URL=http://localhost:8080

# Bearer API key for the agent connecting via MCP.
# Each agent has its own key — this file is agent-scoped.
CREAM_API_KEY=your-agent-api-key-here

# Transport mode: "stdio" (default) or "http"
# stdio → used by Claude Desktop, local agents spawned as a process
# http  → used by remote agents connecting over the network
MCP_TRANSPORT=stdio

# Port for HTTP transport mode (ignored when MCP_TRANSPORT=stdio).
MCP_HTTP_PORT=3002
